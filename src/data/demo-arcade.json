    },
    {
      "id": "arcade-formula-lead",
      "name": "Laser Lead",
      "code": "((t * 5 & t >> 7) | (t * 3 & t >> 10))",
      "leftCode": "((t * 5 & t >> 7) | (t * 3 & t >> 10))",
      "rightCode": "((t * 5 & t >> 7) | (t * 3 & t >> 10))",
      "stereo": false
    },

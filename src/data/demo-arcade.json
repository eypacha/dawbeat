  "formulas": [
    {
      "id": "arcade-formula-bass",
      "name": "Bass Grid",
      "code": "((t >> 4) * ((a & 7) + 2)) & 96",
      "leftCode": "((t >> 4) * ((a & 7) + 2)) & 96",
      "rightCode": "((t >> 4) * ((a & 7) + 2)) & 96",
